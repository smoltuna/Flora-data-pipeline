# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://flora:flora@localhost:5432/flora

# ─── Main LLM ────────────────────────────────────────────────────────────────
# Which provider to use for RAG synthesis: ollama | gemini | groq | together | openai
# Default is ollama (runs locally, no API key needed).
LLM_PROVIDER=ollama

# Ollama (local) — also always used for embeddings + translation
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
# Install models:  ollama pull llama3.2:3b && ollama pull nomic-embed-text

# Only fill in the key for the provider you chose above:
# GROQ_API_KEY=           # https://console.groq.com
# GEMINI_API_KEY=         # https://aistudio.google.com/apikey
# TOGETHER_API_KEY=
# OPENAI_API_KEY=

# Translation provider — defaults to ollama (no rate limits, runs locally).
# Only switch to a cloud provider if you have a paid account with enough quota.
TRANSLATION_PROVIDER=ollama

# ─── Per-Step Providers (Session 4) ─────────────────────────────────────────
# Override provider per pipeline step. Leave empty to use LLM_PROVIDER default.
EMBED_PROVIDER=ollama               # ollama | openai
# GRADE_PROVIDER=                   # ollama | groq | gemini (cheap model OK)
# QUERY_GEN_PROVIDER=               # ollama | groq | gemini
# JUDGE_PROVIDER=                   # ollama | groq | gemini

# Per-step Ollama model overrides (only used when step provider is ollama).
# Leave empty to use OLLAMA_LLM_MODEL default.
# GRADE_MODEL=llama3.2:1b           # tiny model for yes/no grading
# QUERY_GEN_MODEL=llama3.2:3b       # query rewriting
# SYNTH_MODEL=llama3.2:3b           # synthesis (main quality model)
# JUDGE_MODEL=llama3.2:3b           # LLM-as-judge evaluation

# OpenAI embeddings (when EMBED_PROVIDER=openai)
# OPENAI_EMBED_MODEL=text-embedding-3-small

# ─── Web Search (Session 3) ──────────────────────────────────────────────────
# DuckDuckGo search + httpx/bs4 scraping. No API key needed.
# Set to false to disable web search gracefully.
WEB_SEARCH_ENABLED=true

# Chunking config — applied to wikipedia and web_tavily sources
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ─── Quality Gate (Session 8) ────────────────────────────────────────────────
# Fields scoring below this on factual_accuracy are logged as warnings.
QUALITY_GATE_THRESHOLD=0.5

# ─── Image Pipeline ──────────────────────────────────────────────────────────
# fal.ai — used for vision judging (picks best photo) and FLUX lock icon generation.
# Get a key at https://fal.ai/dashboard/keys
FAL_KEY=

# ─── Optional ────────────────────────────────────────────────────────────────
# AWS S3 (artifact storage — only needed for production/deployment)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=flora-assets

# MLflow (experiment tracking UI)
MLFLOW_TRACKING_URI=http://localhost:5001

# App
LOG_LEVEL=INFO
ENVIRONMENT=development
