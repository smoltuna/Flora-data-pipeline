{
  "title": "Flora Pipeline",
  "uid": "flora-pipeline",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(http_server_duration_milliseconds_count[1m])",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP P95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(http_server_duration_milliseconds_bucket[5m]))",
          "legendFormat": "p95 {{http_route}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Pipeline Runs (flower spans + latin_name)",
      "type": "table",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ name=\"flower\" } | select(.latin_name, .flower_id)",
          "tableType": "spans",
          "limit": 50
        }
      ]
    },
    {
      "id": 4,
      "title": "Pipeline Step Durations (latest)",
      "type": "table",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "targets": [
        {
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ name=~\"scrape|embed|retrieve|grade|dedup|extract|synthesize|verify|judge|translate\" }",
          "tableType": "spans",
          "limit": 50
        }
      ]
    }
  ]
}
